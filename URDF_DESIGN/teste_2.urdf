<robot name = "linkage">
      
		<link name = "base_link">	</link>


	    
		<link name = "link A"> 
			<inertial>

				<origin xyz = "0 0 0" />
				<mass value = "0.5" />
				<inertia ixx = "0.5"  iyy = "0.5" izz = "0.5" 
				ixy = "0" ixz = "0" iyz = "0" />
			</inertial>
			<visual>
				<origin xyz = "0 0 0" />
				<geometry>
						<box size = "0.5 0.5 0.1" />
				</geometry>
				<material name = "gray A">
					<color rgba = "0.3 0.3 0.3 1" />
				</material>
			</visual>
		</link >




		<link name = "link B"> 
			<inertial>

				<origin xyz = "0 0 -0.2" />
				<mass value = "0.5" />
				<inertia 
				ixx = "0.5"   iyy = "0.5"      izz = "0.5" 
				ixy = "0"     ixz = "0"       iyz = "0" />

			</inertial>

			<visual>

				<origin xyz = "0 0 -0.5" />

				<geometry>
					<cylinder radius = "0.05" length = "1"  />
				</geometry>

				<material name = "gray b">
					<color rgba = "0.10 0.3 0.3 1" />
				</material>

			</visual>
		</link >



		<link name = "link C"> 
			<inertial>

				<origin xyz = "0 0 0" />
				<mass value = "0.5" />
				<inertia ixx = "0.5"  iyy = "0.5" izz = "0.5" 
				ixy = "0" ixz = "0" iyz = "0" />
			</inertial>
			<visual>
				<origin xyz = "0 0 0" />
				<geometry>
						<box size = "0.5 0.5 0.1" />
				</geometry>
				<material name = "gray A">
					<color rgba = "0.3 0.3 0.3 1" />
				</material>
			</visual>
		</link >

<joint name = "joint C" type = "prismatic">
		<parent link = "base_link" />
		<child  link = "link B" />
		<origin xyz = "0 0 -1" />
		<axis xyz = "0 1 0" />
		    <limit lower="0.0" upper="0.5" effort="10" velocity="0.2"/>
		<dynamics damping ="0.002" />
</joint>


<joint name = "joint A" type = "continuous">
		<parent link = "link B" />
		<child  link = "link A" />
		<origin xyz = "0 0 0" />
		<axis xyz = "0 0 1" />
		<dynamics damping ="0.002" />
</joint>

<joint name = "joint B" type = "continuous">
		<parent link = "link B" />
		<child  link = "link C" />
		<origin xyz = "0 0 -1" />
		<axis xyz = "0 0 1" />
		<dynamics damping ="0.002" />
</joint>






</robot>