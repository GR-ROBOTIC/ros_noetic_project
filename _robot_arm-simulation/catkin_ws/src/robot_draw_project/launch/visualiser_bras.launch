<launch>
  <param name="robot_description" textfile="$(find robot_draw_project)/urdf/mon_bras_6axes.urdf" />

  <node name="joint_state_publisher_gui" pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" />

  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />

  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find robot_draw_project)/launch/config.rviz" required="true" />
</launch>