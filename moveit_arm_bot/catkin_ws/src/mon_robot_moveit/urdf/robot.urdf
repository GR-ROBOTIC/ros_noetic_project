<?xml version="1.0"?>
<robot name="robot_4axes">
  <material name="blue"><color rgba="0 0 0.8 1"/></material>
  <material name="white"><color rgba="1 1 1 1"/></material>

  <link name="base_link">
    <visual><geometry><cylinder length="0.1" radius="0.1"/></geometry><material name="blue"/></visual>
  </link>

  <joint name="waist_joint" type="revolute">
    <parent link="base_link"/><child link="link_1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <link name="link_1">
    <visual><origin xyz="0 0 0.1"/><geometry><cylinder length="0.2" radius="0.05"/></geometry><material name="white"/></visual>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="link_1"/><child link="link_2"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit effort="100" lower="-1.57" upper="1.57" velocity="1.0"/>
  </joint>

  <link name="link_2">
    <visual><origin xyz="0 0 0.1"/><geometry><box size="0.05 0.05 0.2"/></geometry><material name="blue"/></visual>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="link_2"/><child link="link_3"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit effort="100" lower="-1.57" upper="1.57" velocity="1.0"/>
  </joint>

  <link name="link_3">
    <visual><origin xyz="0 0 0.1"/><geometry><box size="0.05 0.05 0.2"/></geometry><material name="white"/></visual>
  </link>

  <joint name="wrist_joint" type="revolute">
    <parent link="link_3"/><child link="link_4"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <link name="link_4">
    <visual><origin xyz="0 0 0.05"/><geometry><cylinder length="0.1" radius="0.03"/></geometry><material name="blue"/></visual>
  </link>

  <joint name="gripper_joint" type="prismatic">
    <parent link="link_4"/><child link="finger_l"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit effort="10" lower="0" upper="0.05" velocity="0.5"/>
  </joint>

  <link name="finger_l">
    <visual><geometry><box size="0.01 0.02 0.05"/></geometry><material name="white"/></visual>
  </link>
</robot>