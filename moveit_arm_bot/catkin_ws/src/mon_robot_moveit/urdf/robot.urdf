<?xml version="1.0" encoding="utf-8"?>
<robot name="robot_4axes">

  <material name="blue"><color rgba="0.0 0.0 0.8 1.0"/></material>
  <material name="white"><color rgba="1.0 1.0 1.0 1.0"/></material>
  <material name="grey"><color rgba="0.3 0.3 0.3 1.0"/></material>
  <material name="red"><color rgba="0.8 0.0 0.0 1.0"/></material>

  <link name="base_link">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <joint name="waist_joint" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="150.0" velocity="1.0"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><cylinder radius="0.05" length="0.1"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="150.0" velocity="1.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><box size="0.04 0.04 0.3"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="150.0" velocity="1.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 0.1"/>
      <geometry><box size="0.03 0.03 0.2"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="wrist_joint" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.7453" upper="1.7453" effort="100.0" velocity="1.0"/>
  </joint>

  <link name="link_4">
    <visual>
      <origin xyz="0 0 0.03"/>
      <geometry><cylinder radius="0.025" length="0.06"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="50.0" velocity="1.5"/>
  </joint>

  <link name="link_5">
    <visual>
      <origin xyz="0 0 0.015"/>
      <geometry><box size="0.05 0.05 0.03"/></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="50.0" velocity="1.5"/>
  </joint>

  <link name="link_6">
    <visual>
      <origin xyz="0 0 0.015"/>
      <geometry><cylinder radius="0.02" length="0.03"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="finger_joint" type="prismatic">
    <parent link="link_6"/>
    <child link="finger_l"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.05" effort="50.0" velocity="0.1"/>
  </joint>

  <link name="finger_l">
    <visual>
      <origin xyz="0.015 0 0.02"/>
      <geometry><box size="0.01 0.02 0.04"/></geometry>
      <material name="red"/>
    </visual>
  </link>

</robot>
