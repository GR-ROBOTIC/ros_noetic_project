<?xml version="1.0"?>
<robot name="esp32_char">

  <!-- Materiaux -->
  <material name="blue"> <color rgba="0 0 0.8 1"/> </material>
  <material name="black"> <color rgba="0 0 0 1"/> </material>

  <!-- Corps du Robot -->
  <link name="base_link">
    <visual>
      <geometry> 
        <mesh filename="../meshes/robot_body.obj" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- ROUE ARRIERE GAUCHE -->
  <link name="rear_left_wheel">
    <visual>
      <geometry> 
        <mesh filename="../meshes/rear_left_wheel.obj"  scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
      <origin xyz="-0.115 -0.220 -0.040" rpy="0 0 0"/>
    </visual>
  </link>
  <joint name="joint_rear_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="0.115 0.220 0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ROUE ARRIERE DROITE -->
  <link name="rear_right_wheel">
    <visual>
      <geometry> 
        <mesh filename="../meshes/rear_right_wheel.obj"  scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
      <origin xyz="-0.115 0.120 -0.040" rpy="0 0 0"/>
    </visual>
  </link>
  <joint name="joint_rear_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="0.115 -0.120 0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ROUE AVANT GAUCHE -->
  <link name="front_left_wheel">
    <visual>
      <geometry>
        <mesh filename="../meshes/front_left_wheel.obj"  scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="blue"/>
      <origin xyz="0.100 -0.220 -0.040" rpy="0 0 0"/>
    </visual>
  </link>
  <joint name="joint_front_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="-0.100 0.220 0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ROUE AVANT DROITE -->
  <link name="front_right_wheel">
    <visual>
      <geometry> 
        <mesh filename="../meshes/front_right_wheel.obj"    scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0.100 0.120 -0.045" rpy="0 0 0"/>
    </visual>
  </link>
  <joint name="joint_front_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="-0.100 -0.120 0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- LIDAR -->
  <link name="laser">
    <visual>
      <geometry> 
        <mesh filename="../meshes/lidar_body.obj" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="joint_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
       <origin xyz="-0.000 -0.000 -0.000" rpy="0 0 0"/>
  </joint>

</robot>