<?xml version="1.0"?>
<robot name="esp32_char">

  <material name="blue"> <color rgba="0 0 0.8 1"/> </material>
  <material name="black"> <color rgba="0 0 0 1"/> </material>

  <link name="base_link">
    <visual>
      <geometry> <box size="0.35 0.2 0.1"/> </geometry>
      <material name="blue"/>
    </visual>
  </link>














  <link name="rear_left_wheel">
    <visual>
      <geometry> <cylinder length="0.05" radius="0.05"/> </geometry>
      <material name="black"/>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    </visual>
  </link>
  <joint name="joint_rear_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.1 0.125 0"/>
    <axis xyz="0 1 0"/>
  </joint>
















  <link name="front_left_wheel">
    <visual>
      <geometry> <cylinder length="0.05" radius="0.05"/> </geometry>
      <material name="black"/>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    </visual>
  </link>
  <joint name="joint_front_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.1 0.125 0"/>
    <axis xyz="0 1 0"/>
  </joint>










  <link name="rear_right_wheel">
    <visual>
      <geometry> <cylinder length="0.05" radius="0.05"/> </geometry>
      <material name="black"/>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    </visual>
  </link>
  <joint name="joint_rear_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.1 -0.125 0"/>
    <axis xyz="0 1 0"/>
  </joint>






  <link name="front_right_wheel">
    <visual>
      <geometry> <cylinder length="0.05" radius="0.05"/> </geometry>
      <material name="black"/>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    </visual>
  </link>
  <joint name="joint_front_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.1 -0.125 0"/>
    <axis xyz="0 1 0"/>
  </joint>





<link name="laser">
    <visual>
      <geometry> <cylinder length="0.04" radius="0.035"/> </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="joint_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.1 0 0.07" rpy="0 0 0"/>
  </joint>



</robot>