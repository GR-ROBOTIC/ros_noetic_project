<launch>
  <param name="robot_description" textfile="$(find esp32_control)/urdf/robot_physique.urdf" />

  <!--node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
      <param name="serial_port"         type="string" value="/dev/ttyUSB1"/>
      <param name="serial_baudrate"     type="int"    value="115200"/>
      <param name="frame_id"            type="string" value="laser"/> 
      <param name="inverted" type="bool"   value="false"/>
      <param name="angle_compensate"    type="bool"   value="true"/>
  </node -->
  <node name="esp32_odom" pkg="esp32_control" type="odom_virtual.py" output="screen" />
  <!--node name="esp32_odom" pkg="esp32_control" type="esp32_odom.py" output="screen" /-->
  <node name="robot_gui" pkg="esp32_control" type="ros_gui_control.py" output="screen" />
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />
  
  <node name="rviz" pkg="rviz" type="rviz" required="true" />



<!--node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="odom"/>
    <param name="map_frame"  value="map"/>
    <param name="map_update_interval" value="1.0"/>
    <param name="maxUrange" value="10.0"/>
    <param name="delta" value="0.05"/> </node -->
    
</launch>