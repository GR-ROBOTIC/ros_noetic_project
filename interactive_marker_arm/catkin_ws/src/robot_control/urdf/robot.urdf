<?xml version="1.0"?>
<robot name="robot_4axes_ik">

  <!-- Matériaux pour l'esthétique du robot dans RViz -->
  <material name="dark_grey"><color rgba="0.15 0.15 0.15 1"/></material>
  <material name="blue"><color rgba="0.0 0.4 0.8 1"/></material>
  <material name="white"><color rgba="0.95 0.95 0.95 1"/></material>
  <material name="orange"><color rgba="1.0 0.5 0.0 1"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>

  <!-- ================= BASE LINK ================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.15"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>

  <!-- Joint 1 : Rotation de la base autour de l'axe vertical Z (Yaw) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="100.0" velocity="1.5"/>
  </joint>

  <!-- ================= LINK 1 ================= -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0.1375" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.275" radius="0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- Joint 2 : Épaule (Rotation autour de Y - Pitch) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.275" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="100.0" velocity="1.5"/>
  </joint>

  <!-- ================= LINK 2 ================= -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.30"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- Joint 3 : Coude (Rotation autour de Y - Pitch) -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="100.0" velocity="1.5"/>
  </joint>

  <!-- ================= LINK 3 ================= -->
  <link name="link3">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.20"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- Joint 4 : Poignet (Rotation autour de Y - Pitch) -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="100.0" velocity="1.5"/>
  </joint>

  <!-- ================= GRIPPER BASE ================= -->
  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.12 0.05"/>
      </geometry>
      <material name="orange"/>
    </visual>
  </link>

  <!-- Joint Doigt 1 : Prismatique gauche (Axe Y) -->
  <joint name="gripper_finger1_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_finger1"/>
    <origin xyz="0 0.04 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="50.0" velocity="0.5"/>
  </joint>

  <link name="gripper_finger1">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.01 0.05"/>
      </geometry>
      <material name="grey"/>
    </visual>
  </link>

  <!-- Joint Doigt 2 : Prismatique droit (Axe -Y) -->
  <joint name="gripper_finger2_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_finger2"/>
    <origin xyz="0 -0.04 0.05" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.04" effort="50.0" velocity="0.5"/>
  </joint>

  <link name="gripper_finger2">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.01 0.05"/>
      </geometry>
      <material name="grey"/>
    </visual>
  </link>

</robot>