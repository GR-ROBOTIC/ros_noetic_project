<?xml version="1.0"?>
<robot name="tf_slider_robot">

  <!-- Définition des matériaux -->
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>
  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>
  <material name="yellow">
    <color rgba="1 1 0 1"/>
  </material>
  <material name="purple">
    <color rgba="0.5 0 0.5 1"/>
  </material>

  <!-- Base link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.2 0.2 0.2"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- Link1 -->
  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="package://tf_slider_demo/meshes/tinker.obj"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <!-- Link2 -->
  <link name="link2">
    <visual>
      <geometry>
        <mesh filename="package://tf_slider_demo/meshes/tinker1.obj"/>
      </geometry>
      <material name="green"/>
    </visual>
  </link>

  <!-- Link3 -->
  <link name="link3">
    <visual>
      <geometry>
        <mesh filename="package://tf_slider_demo/meshes/tinker2.obj"/>
      </geometry>
          <origin xyz="0 0 -70" rpy="0 0 0"/>
      <material name="yellow"/>
    </visual>
  </link>

  <!-- Link4 -->
  <link name="link4">
    <visual>
      <geometry>
        <mesh filename="package://tf_slider_demo/meshes/tinker3.obj"/>
      </geometry>
          <origin xyz="0 -20 -90" rpy="0 0 0"/>
      <material name="yellow"/>
    </visual>
  </link>


  <!-- Joints fixes pour rattacher les links à la base -->
  <joint name="base_to_link1" type="continuous">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="base_to_link2" type="continuous">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

  <joint name="base_to_link3" type="continuous">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 70" rpy="0 0 0"/>
  </joint>

<joint name="base_to_link4" type="continuous">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 30 20" rpy="0 0 0"/>
  </joint>

</robot>