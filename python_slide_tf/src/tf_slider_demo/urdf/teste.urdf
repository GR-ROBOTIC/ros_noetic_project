<?xml version="1.0"?>
<robot name="tf_slider_robot">

  <!-- Définition des matériaux -->


<material name="red">  <color rgba="1 0 0 1"/>   </material>
<material name="blue">  <color rgba="1 0 0 1"/>   </material>





  <!-- Base link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.2 0.2 0.2"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>




  <!-- Link1 -->
  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="package://tf_slider_demo/meshes/tinker.obj"/>
      </geometry>
      <material name="red"/>
      <origin xyz="5 0 0" rpy="0 0 0"/>
    </visual>
  </link>


 <!--  Link2   -->
  <link name="link2">
    <visual>
      <geometry>
      <mesh filename = "package://tf_slider_demo/meshes/tinker1.obj"/>
      </geometry>
      <origin xyz="5 0 -20" rpy="0 0 0"/>
    </visual>
  </link>



 <!--  Link3   -->
  <link name="link3">
    <visual>
      <geometry>
      <mesh filename = "package://tf_slider_demo/meshes/tinker2.obj"/>
      </geometry>
      <origin xyz="5 10 -70" rpy=" 0 0 0 "/>
    </visual>
  </link>








  <joint name="arm_base_axe" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="1 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="3.14159" effort="1" velocity="1"/>
    
  </joint>


  <joint name="arm_axe_1" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 20" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="3.14159" effort="1" velocity="1"/>
  </joint>



  <joint name="arm_axe_2" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 45" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="3.14159" effort="1" velocity="1"/>
  </joint>







</robot>
